# =============================================================================
# AEROFINDER — Variables de entorno
# Copiar a .env y completar los valores antes de ejecutar docker compose up
# NUNCA commitear el archivo .env al repositorio
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aerofinder

# Superusuario (solo para inicialización de la DB)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambiar_en_produccion_superuser

# Rol de la aplicación FastAPI (DML en tablas de negocio)
POSTGRES_APP_PASSWORD=cambiar_en_produccion_app

# Rol del worker de IA (INSERT en telemetría y detecciones)
POSTGRES_WORKER_PASSWORD=cambiar_en_produccion_worker

# Rol de auditoría legal (SELECT en logs)
POSTGRES_AUDIT_PASSWORD=cambiar_en_produccion_audit

# URLs completas para SQLAlchemy (asyncpg)
DATABASE_URL=postgresql+asyncpg://aerofinder_app:cambiar_en_produccion_app@postgres:5432/aerofinder
DATABASE_URL_WORKER=postgresql+asyncpg://aerofinder_worker:cambiar_en_produccion_worker@postgres:5432/aerofinder

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# Nombres de los Streams en Redis
REDIS_STREAM_TELEMETRY=aerofinder:telemetry
REDIS_STREAM_DETECTIONS=aerofinder:detections
REDIS_STREAM_NOTIFICATIONS=aerofinder:notifications

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=cambiar_en_produccion_minio

# Credenciales de acceso para la aplicación (crear desde la consola MinIO)
MINIO_ACCESS_KEY=aerofinder_access_key
MINIO_SECRET_KEY=cambiar_en_produccion_minio_secret

MINIO_URL=http://minio:9000
MINIO_SECURE=false

# Nombres de buckets
MINIO_BUCKET_SNAPSHOTS=aerofinder-snapshots
MINIO_BUCKET_PHOTOS=aerofinder-photos
MINIO_BUCKET_VIDEOS=aerofinder-videos

# ── MediaMTX ──────────────────────────────────────────────────────────────────
MEDIAMTX_API_URL=http://mediamtx:9997
MEDIAMTX_RTMP_URL=rtmp://mediamtx:1935
MEDIAMTX_RTSP_URL=rtsp://mediamtx:8554
MEDIAMTX_HLS_URL=http://mediamtx:8888

# ── Backend FastAPI ───────────────────────────────────────────────────────────
# Clave secreta para firmar JWT — mínimo 32 caracteres aleatorios
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar_en_produccion_min_32_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

ENVIRONMENT=development
BACKEND_PORT=8000

# Orígenes permitidos para CORS (separados por coma)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# ── AI Worker ─────────────────────────────────────────────────────────────────
# Directorio de modelos (montado como volumen Docker)
MODELS_DIR=/models
YOLO_MODEL_PATH=/models/yolov8n.pt
INSIGHTFACE_MODEL_DIR=/models/insightface

# ── Frontend Next.js ──────────────────────────────────────────────────────────
# Variables públicas (expuestas en el bundle JS del browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_HLS_URL=http://localhost:8888
